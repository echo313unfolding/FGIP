[Unit]
Description=FGIP Tier 2 Agents (Promethean, YouTube)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/voidstr3m33/fgip-engine
Environment="PYTHONPATH=/home/voidstr3m33/fgip-engine"
ExecStart=/usr/bin/python3 tools/schedule_runner.py --tier 2 --db fgip.db
StandardOutput=append:/home/voidstr3m33/fgip-engine/receipts/schedule/tier2.log
StandardError=append:/home/voidstr3m33/fgip-engine/receipts/schedule/tier2.log
